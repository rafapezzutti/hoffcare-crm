DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require
JWT_SECRET=minha-chave-super-secreta-hoffcare-2024
NODE_ENV=development
PORT=3001

# ── Vertex AI (Google Cloud) ──────────────────────────────────────────────────
# ID do projeto no Google Cloud Console
GOOGLE_CLOUD_PROJECT=meu-projeto-google-cloud

# Região (us-central1 recomendado; southamerica-east1 para dados no Brasil)
GOOGLE_CLOUD_LOCATION=us-central1

# Modelo Gemini a usar (gemini-2.0-flash-001 é o mais rápido e econômico)
VERTEX_MODEL=gemini-2.0-flash-001

# Credenciais da Service Account em formato JSON (uma única linha)
# Gerado em: Google Cloud Console → IAM → Service Accounts → Chaves → JSON
# Para converter para uma linha: cat chave.json | tr -d '\n'
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}